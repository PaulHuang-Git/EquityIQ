# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35b-a3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_PRICE=3600        # 1 hour  — stock price data
REDIS_TTL_FINANCIALS=86400  # 24 hours — financial statements
REDIS_TTL_LLM=21600         # 6 hours  — LLM response semantic cache

# ── SQLite ────────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./database/financial_analyzer.db

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ── Default tickers ───────────────────────────────────────────────────────────
DEFAULT_TICKERS=AAPL,MSFT,GOOGL,JPM,XOM

# ── Weaviate (Phase 2 — leave blank for Phase 1) ──────────────────────────────
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
